{
  "name": "agent-sandbox-platform",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "agent-sandbox-platform",
      "version": "0.1.0",
      "workspaces": [
        "apps/*",
        "packages/*",
        "tests"
      ],
      "engines": {
        "node": ">=22.19.0"
      }
    },
    "apps/control-plane": {
      "name": "@geminixiang/sandbox-control-plane",
      "version": "0.1.0",
      "dependencies": {
        "@geminixiang/sandbox-contracts": "0.1.0"
      },
      "engines": {
        "node": ">=22.19.0"
      }
    },
    "node_modules/@geminixiang/sandbox-contract-tests": {
      "resolved": "tests",
      "link": true
    },
    "node_modules/@geminixiang/sandbox-contracts": {
      "resolved": "packages/contracts",
      "link": true
    },
    "node_modules/@geminixiang/sandbox-control-plane": {
      "resolved": "apps/control-plane",
      "link": true
    },
    "node_modules/@geminixiang/sandbox-sdk": {
      "resolved": "packages/sdk-typescript",
      "link": true
    },
    "packages/contracts": {
      "name": "@geminixiang/sandbox-contracts",
      "version": "0.1.0",
      "license": "MIT",
      "engines": {
        "node": ">=22.19.0"
      }
    },
    "packages/sdk-typescript": {
      "name": "@geminixiang/sandbox-sdk",
      "version": "0.1.0",
      "license": "MIT",
      "engines": {
        "node": ">=22.19.0"
      }
    },
    "tests": {
      "name": "@geminixiang/sandbox-contract-tests"
    }
  }
}
